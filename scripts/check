#!/usr/bin/env bash
# The full pre-commit / CI gate: format check, lints, and tests.
# Composes the smaller scripts so each command has a single source of truth.
# Does not modify files (unlike lint-autofix).
set -euo pipefail
cd "$(dirname "$0")/.."

echo "==> rustfmt --check"
./scripts/fmt-check

echo "==> clippy (warnings as errors)"
./scripts/lint

echo "==> tests"
./scripts/test
